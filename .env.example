# ============================================================
# Overnight Childcare Booking App — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# ============================================================

# ─── Database (Prisma) ──────────────────────────────────────
# PostgreSQL connection string — used by Prisma for migrations
# and schema management. Get this from Supabase Dashboard →
# Settings → Database → Connection string (URI).
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# ─── Supabase ───────────────────────────────────────────────
# Project URL and keys — found in Supabase Dashboard →
# Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ─────────────────────────────────────────────────
# API keys from https://dashboard.stripe.com/test/apikeys
# Webhook secret from Stripe Dashboard → Developers → Webhooks
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development
