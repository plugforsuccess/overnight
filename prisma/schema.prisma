// ============================================================
// Overnight Childcare Booking – Prisma Schema
// ============================================================
//
// CANONICAL SCHEMA SOURCE OF TRUTH
//
// This file is the single authoritative definition of the application schema.
// All schema changes go through Prisma migrations (`npx prisma migrate dev`).
//
// NOT managed by Prisma (remain in SQL):
//   - RLS policies (supabase/rls-policies.sql)
//   - Triggers: update_timestamp (global updated_at), enforce_max_two_emergency_contacts
//   - Functions: handle_new_user (auth.users → parents auto-create)
//   - Functions: update_timestamp (global updated_at automation)
//   - Postgres enums: allergy_type, allergy_severity, treatment_type
//   - CHECK constraints (enforced at DB level, documented inline)
//   - Partial unique indexes (documented inline)
//
// Identity model:
//   parents.id = auth.users.id (set by handle_new_user() trigger).
//   The FK to auth.users(id) ON DELETE CASCADE exists at the DB level
//   but is not modeled here because Prisma cannot reference auth schema.
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── centers ─────────────────────────────────────────────────────────────────
// Physical childcare center. Even single-center deployments get one row.
model Center {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name           String
  slug           String   @unique
  timezone       String   @default("America/New_York")
  address_line_1 String?
  city           String?
  state          String?
  postal_code    String?
  is_active      Boolean  @default(true)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  programs          Program[]
  program_capacities ProgramCapacity[]
  capacity_overrides CapacityOverride[]

  @@map("centers")
}

// ─── programs ────────────────────────────────────────────────────────────────
// A care offering at a center (e.g., "Overnight Care").
// Pricing is handled separately via plans table.
model Program {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  center_id  String  @db.Uuid
  name       String
  care_type  String  @default("overnight") // CHECK: overnight | daycare | drop_in
  start_time String  @default("21:00")
  end_time   String  @default("07:00")
  age_min_months Int? // minimum age in months
  age_max_months Int? // maximum age in months
  is_active  Boolean @default(true)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  center             Center            @relation(fields: [center_id], references: [id], onDelete: Cascade)
  program_capacities ProgramCapacity[]
  capacity_overrides CapacityOverride[]

  @@map("programs")
}

// ─── program_capacity ────────────────────────────────────────────────────────
// One row per program per date. Source of truth for night-level availability.
// CHECK: status IN (open, full, closed)
model ProgramCapacity {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  center_id            String   @db.Uuid
  program_id           String   @db.Uuid
  care_date            DateTime @db.Date
  capacity_total       Int
  capacity_reserved    Int      @default(0)
  capacity_waitlisted  Int      @default(0)
  status               String   @default("open") // CHECK: open | full | closed

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  center            Center            @relation(fields: [center_id], references: [id], onDelete: Cascade)
  program           Program           @relation(fields: [program_id], references: [id], onDelete: Cascade)
  reservation_nights ReservationNight[]

  @@unique([program_id, care_date], map: "program_capacity_program_date_unique")
  @@index([care_date, status], map: "idx_program_capacity_date_status")
  @@map("program_capacity")
}

// ─── capacity_overrides ──────────────────────────────────────────────────────
// Operator-managed per-date overrides for closures and reduced capacity.
// Partial unique index: one active override per (program_id, care_date).
// CHECK: override_type IN (closed, reduced_capacity, reopened)
// CHECK: reason_code IN (holiday, staff_shortage, weather, facility_issue, emergency_closure, low_demand, maintenance, other)
model CapacityOverride {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  center_id          String    @db.Uuid
  program_id         String    @db.Uuid
  care_date          DateTime  @db.Date
  override_type      String    // closed | reduced_capacity | reopened
  capacity_override  Int?
  reason_code        String    // holiday | staff_shortage | weather | facility_issue | emergency_closure | low_demand | maintenance | other
  reason_text        String?
  is_active          Boolean   @default(true)
  created_by_user_id String    @db.Uuid
  updated_by_user_id String?   @db.Uuid

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  center Center @relation(fields: [center_id], references: [id], onDelete: Cascade)
  program Program @relation(fields: [program_id], references: [id], onDelete: Cascade)
  events  CapacityOverrideEvent[]

  @@index([center_id, care_date], map: "idx_capacity_overrides_center_date")
  @@index([program_id, care_date], map: "idx_capacity_overrides_program_date")
  @@index([is_active, care_date], map: "idx_capacity_overrides_active")
  @@index([created_by_user_id], map: "idx_capacity_overrides_created_by")
  @@map("capacity_overrides")
}

// ─── capacity_override_events ────────────────────────────────────────────────
// Immutable audit trail for closure/reduction operator actions.
model CapacityOverrideEvent {
  id                    String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  capacity_override_id  String   @db.Uuid
  center_id             String   @db.Uuid
  program_id            String   @db.Uuid
  care_date             DateTime @db.Date
  actor_user_id         String   @db.Uuid
  event_type            String
  event_at              DateTime @default(now()) @db.Timestamptz(6)
  metadata              Json     @default("{}") @db.JsonB

  // Relations
  capacity_override CapacityOverride @relation(fields: [capacity_override_id], references: [id], onDelete: Cascade)

  @@index([capacity_override_id, event_at], map: "idx_override_events_override")
  @@index([center_id, care_date], map: "idx_override_events_center_date")
  @@index([event_type, event_at], map: "idx_override_events_type")
  @@index([actor_user_id], map: "idx_override_events_actor")
  @@map("capacity_override_events")
}

// ─── parents ──────────────────────────────────────────────────────────────────
// parents.id is set to auth.users.id by the handle_new_user() trigger.
// No default — ID comes from Supabase Auth, not auto-generated.
model Parent {
  id                 String   @id @db.Uuid
  first_name         String
  last_name          String
  email              String   @unique
  phone              String?
  address            String?
  role               String   @default("parent")  // CHECK: parent | admin
  is_admin           Boolean  @default(false)
  stripe_customer_id String?  @unique
  name               String?  // legacy column, nullable
  center_id          String?  @db.Uuid
  onboarding_status  String   @default("started") // CHECK: started | parent_profile_complete | child_created | medical_ack_complete | emergency_contact_added | complete

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  children         Child[]
  overnight_blocks OvernightBlock[]
  waitlist_entries WaitlistEntry[]
  credits          Credit[]
  payments         Payment[]
  subscriptions    Subscription[]
  audit_logs       AuditLog[]
  pickup_verifications PickupEvent[] @relation("pickup_verifier")
  settings        ParentSettings?
  staff_memberships CenterStaffMembership[]
  billing_ledger    BillingLedger[]

  @@map("parents")
}

// ─── children ─────────────────────────────────────────────────────────────────
model Child {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id      String    @db.Uuid
  first_name     String
  last_name      String
  middle_name    String?
  preferred_name String?
  date_of_birth  DateTime? @db.Date
  gender         String?
  name           String?   // legacy column, nullable
  allergies      String?   // legacy text column
  photo_url      String?
  medical_notes  String?
  notes          String?
  active         Boolean   @default(true)
  archived_at    DateTime? @db.Timestamptz(6)
  center_id      String?   @db.Uuid

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  parent             Parent                @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  overnight_blocks   OvernightBlock[]
  reservations       Reservation[]
  waitlist_entries   WaitlistEntry[]
  child_allergies    ChildAllergy[]
  emergency_contacts ChildEmergencyContact[]
  authorized_pickups ChildAuthorizedPickup[]
  pickup_events         PickupEvent[]
  medical_profile       ChildMedicalProfile?
  events                ChildEvent[]
  attendance_sessions   ChildAttendanceSession[]
  incident_reports      IncidentReport[]
  reservation_nights    ReservationNight[]
  billing_ledger        BillingLedger[]
  documents             ChildDocument[]
  immunization_record   ChildImmunizationRecord?
  medication_authorizations MedicationAuthorization[]

  @@index([parent_id], map: "idx_children_parent_id")
  @@map("children")
}

// ─── child_documents ──────────────────────────────────────────────────────
// Secure document storage for immunization certificates, medication
// authorization forms, photo IDs, and other licensing-required files.
// Files live in Supabase Storage; this table tracks metadata.
model ChildDocument {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id      String    @db.Uuid
  center_id     String?   @db.Uuid
  document_type String    // immunization_certificate | medication_authorization | photo_id | consent_form | other
  file_name     String
  file_url      String    // Supabase Storage signed URL or path
  file_size     Int?
  mime_type     String?
  uploaded_by   String    @db.Uuid
  expires_at    DateTime? @db.Timestamptz(6)
  verified      Boolean   @default(false)
  verified_by   String?   @db.Uuid
  verified_at   DateTime? @db.Timestamptz(6)
  notes         String?
  is_active     Boolean   @default(true)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child Child @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@index([child_id, document_type], map: "idx_child_documents_child_type")
  @@map("child_documents")
}

// ─── child_immunization_records ──────────────────────────────────────────
// Tracks immunization status per child. Georgia DECAL requires Form 3231
// (Certificate of Immunization) on file for every enrolled child.
// CHECK: status IN (current, expired, exempt_medical, exempt_religious, missing)
model ChildImmunizationRecord {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id       String    @unique @db.Uuid
  center_id      String?   @db.Uuid
  status         String    @default("missing") // current | expired | exempt_medical | exempt_religious | missing
  document_url   String?   // path in Supabase Storage (child-documents bucket)
  document_path  String?   // storage key for deletion
  issued_date    DateTime? @db.Date
  expires_at     DateTime? @db.Date
  exemption_reason String?
  verified_by    String?   @db.Uuid
  verified_at    DateTime? @db.Timestamptz(6)
  notes          String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child Child @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@map("child_immunization_records")
}

// ─── medication_authorizations ───────────────────────────────────────────
// Written parental authorization for each medication a child may receive
// in care. Georgia DECAL requires signed authorization before any medication
// can be administered. Covers routine meds (antibiotics, ADHD, seizure, etc.)
// that allergy action plans do not cover.
model MedicationAuthorization {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id                String    @db.Uuid
  center_id               String?   @db.Uuid
  medication_name         String
  dosage                  String
  route                   String    // oral | topical | inhaled | injection | other
  frequency               String    // e.g. "every 4 hours", "twice daily", "as needed"
  start_date              DateTime  @db.Date
  end_date                DateTime? @db.Date
  special_instructions    String?
  prescribing_physician   String?
  parent_consent_name     String?   // name of consenting parent (typed signature)
  parent_consent_signed_at DateTime? @db.Timestamptz(6)
  document_url            String?   // signed authorization form upload
  is_active               Boolean   @default(true)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child                Child                        @relation(fields: [child_id], references: [id], onDelete: Cascade)
  administration_logs  MedicationAdministrationLog[]

  @@index([child_id, is_active], map: "idx_med_auth_child_active")
  @@map("medication_authorizations")
}

// ─── medication_administration_logs ──────────────────────────────────────
// Immutable record of each medication administration event.
// Staff logs when medication is actually given to a child.
model MedicationAdministrationLog {
  id                          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  medication_authorization_id String   @db.Uuid
  child_id                    String   @db.Uuid
  administered_at             DateTime @db.Timestamptz(6)
  administered_by             String   @db.Uuid
  dose_given                  String
  notes                       String?
  parent_notified             Boolean  @default(false)

  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  authorization MedicationAuthorization @relation(fields: [medication_authorization_id], references: [id], onDelete: Cascade)

  @@index([child_id, administered_at], map: "idx_med_admin_child_time")
  @@map("medication_administration_logs")
}

// ─── child_allergies ─────────────────────────────────────────────────────────
// allergen uses Postgres enum type `allergy_type`
// severity uses Postgres enum type `allergy_severity`
model ChildAllergy {
  id           String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id     String  @db.Uuid
  allergen     String  // DB enum: allergy_type
  custom_label String?
  severity     String  @default("UNKNOWN") // DB enum: allergy_severity

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child       Child                  @relation(fields: [child_id], references: [id], onDelete: Cascade)
  action_plan ChildAllergyActionPlan?

  @@unique([child_id, allergen, custom_label], map: "child_allergies_child_id_allergen_custom_label_unique")
  @@map("child_allergies")
}

// ─── child_allergy_action_plans ──────────────────────────────────────────────
model ChildAllergyActionPlan {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_allergy_id      String    @unique @db.Uuid
  treatment_first_line  String    @default("NONE") // DB enum: treatment_type
  dose_instructions     String?
  symptoms_watch        Json?     @db.JsonB
  med_location          String?
  requires_med_on_site  Boolean   @default(false)
  medication_expires_on DateTime? @db.Date
  physician_name        String?
  parent_confirmed      Boolean   @default(false)
  parent_confirmed_at   DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child_allergy ChildAllergy @relation(fields: [child_allergy_id], references: [id], onDelete: Cascade)

  @@map("child_allergy_action_plans")
}

// ─── child_medical_profiles ─────────────────────────────────────────────────
// Stores child medical awareness without bloating the child record.
// One-to-one with children (unique child_id).
model ChildMedicalProfile {
  id        String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id  String @unique @db.Uuid
  center_id String? @db.Uuid

  has_allergies          Boolean @default(false)
  has_medications        Boolean @default(false)
  has_medical_conditions Boolean @default(false)

  allergies_summary          String?
  medications_summary        String?
  medical_conditions_summary String?

  physician_name      String?
  physician_phone     String?
  hospital_preference String?

  special_instructions String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child Child @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@map("child_medical_profiles")
}

// ─── child_emergency_contacts ────────────────────────────────────────────────
// DB trigger: enforce_max_two_emergency_contacts() limits to 2 per child
model ChildEmergencyContact {
  id                    String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id              String  @db.Uuid
  center_id             String? @db.Uuid
  first_name            String
  last_name             String
  relationship          String
  phone                 String
  phone_alt             String?
  email                 String?
  is_primary            Boolean @default(false)
  priority              Int
  authorized_for_pickup Boolean @default(false)
  archived_at           DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child Child @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@unique([child_id, priority], map: "child_emergency_contacts_child_id_priority_unique")
  @@unique([child_id, phone], map: "child_emergency_contacts_child_id_phone_unique")
  @@map("child_emergency_contacts")
}

// ─── child_authorized_pickups ────────────────────────────────────────────────
model ChildAuthorizedPickup {
  id                   String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id             String    @db.Uuid
  center_id            String?   @db.Uuid
  first_name           String
  last_name            String
  relationship         String
  phone                String
  email                String?
  dob                  DateTime? @db.Date
  pickup_pin_hash      String?
  photo_id_url         String?
  is_emergency_contact Boolean   @default(false)
  is_active            Boolean   @default(true)
  archived_at          DateTime? @db.Timestamptz(6)
  id_verified          Boolean   @default(false)
  id_verified_at       DateTime? @db.Timestamptz(6)
  id_verified_by       String?   @db.Uuid
  notes                String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child         Child         @relation(fields: [child_id], references: [id], onDelete: Cascade)
  pickup_events PickupEvent[]

  @@map("child_authorized_pickups")
}

// ─── child_events ──────────────────────────────────────────────────────────
// Append-only child safety event ledger. Never update or delete.
// Acts as an operational audit log for childcare operations.
model ChildEvent {
  id         String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id   String  @db.Uuid
  center_id  String? @db.Uuid
  event_type String  // e.g. child_checked_in, child_checked_out, medical_alert_triggered, etc.
  event_data Json    @default("{}") @db.JsonB
  created_by String? @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  child Child @relation(fields: [child_id], references: [id], onDelete: Cascade)

  @@index([child_id, created_at], map: "idx_child_events_child_created")
  @@index([event_type], map: "idx_child_events_type")
  @@map("child_events")
}

// ─── child_attendance_sessions ─────────────────────────────────────────────
// Structured attendance tracking for overnight care sessions.
// Powers staff dashboards, billing calculations, incident reporting, pickup verification.
// CHECK: status IN (scheduled, checked_in, in_care, ready_for_pickup, checked_out, cancelled)
model ChildAttendanceSession {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id        String    @db.Uuid
  center_id       String?   @db.Uuid
  reservation_id  String?   @db.Uuid

  check_in_at     DateTime? @db.Timestamptz(6)
  check_out_at    DateTime? @db.Timestamptz(6)
  checked_in_by   String?   @db.Uuid
  checked_out_by  String?   @db.Uuid

  pickup_person_name   String?
  pickup_relationship  String?
  pickup_verified      Boolean @default(false)

  status String @default("scheduled") // CHECK: scheduled | checked_in | in_care | ready_for_pickup | checked_out | cancelled
  notes  String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child            Child            @relation(fields: [child_id], references: [id], onDelete: Cascade)
  reservation      Reservation?     @relation(fields: [reservation_id], references: [id], onDelete: SetNull)
  incident_reports IncidentReport[]
  pickup_verification PickupVerification?

  @@index([child_id, created_at], map: "idx_attendance_child_created")
  @@index([status], map: "idx_attendance_status")
  @@map("child_attendance_sessions")
}

// ─── reservation_events ────────────────────────────────────────────────────
// Append-only ledger tracking reservation lifecycle history.
// Never update or delete — preserves booking history for billing disputes and audits.
model ReservationEvent {
  id             String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservation_id String  @db.Uuid
  event_type     String  // reservation_created, reservation_confirmed, reservation_cancelled, etc.
  event_data     Json    @default("{}") @db.JsonB
  created_by     String? @db.Uuid
  created_at     DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  reservation Reservation @relation(fields: [reservation_id], references: [id], onDelete: Cascade)

  @@index([reservation_id, created_at], map: "idx_reservation_events_res_created")
  @@index([event_type], map: "idx_reservation_events_type")
  @@map("reservation_events")
}

// ─── incident_reports ──────────────────────────────────────────────────────
// First-class structured incident records linked to attendance sessions.
// Supports legal defensibility, parent notification tracking, and compliance.
// CHECK: severity IN (low, medium, high, critical)
// CHECK: status IN (open, investigating, resolved, closed)
model IncidentReport {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id              String    @db.Uuid
  attendance_session_id String?   @db.Uuid
  center_id             String?   @db.Uuid

  severity String  // CHECK: low | medium | high | critical
  category String  // injury, illness, behavioral, medication_error, safety, other
  summary  String
  details  String?

  reported_by        String?   @db.Uuid
  parent_notified_at DateTime? @db.Timestamptz(6)
  resolved_at        DateTime? @db.Timestamptz(6)
  closed_at          DateTime? @db.Timestamptz(6)
  status             String    @default("open") // CHECK: open | investigating | resolved | closed

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child              Child                   @relation(fields: [child_id], references: [id], onDelete: Cascade)
  attendance_session ChildAttendanceSession? @relation(fields: [attendance_session_id], references: [id], onDelete: SetNull)

  @@index([child_id, created_at], map: "idx_incident_reports_child_created")
  @@index([status], map: "idx_incident_reports_status")
  @@index([severity], map: "idx_incident_reports_severity")
  @@map("incident_reports")
}

// ─── center_staff_memberships ──────────────────────────────────────────────
// Normalized staff/center role assignment for multi-center RLS.
// Replaces ad hoc role flags with explicit membership records.
// CHECK: role IN (staff, admin, center_admin, super_admin)
model CenterStaffMembership {
  id        String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  user_id   String  @db.Uuid
  center_id String  @db.Uuid
  role        String  // CHECK: staff | admin | center_admin | super_admin
  active      Boolean @default(true)
  archived_at DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  user Parent @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, center_id], map: "center_staff_memberships_user_center_unique")
  @@index([center_id, active], map: "idx_staff_memberships_center_active")
  @@map("center_staff_memberships")
}

// ─── pickup_verifications ──────────────────────────────────────────────────
// Dedicated immutable record of each pickup verification event.
// High-risk enough to warrant first-class storage separate from attendance.
// One-to-one with attendance session (one verification per session).
model PickupVerification {
  id                     String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attendance_session_id  String  @unique @db.Uuid
  authorized_pickup_id   String? @db.Uuid
  verified_name          String
  verified_relationship  String
  verification_method    String  // pin, photo_id, parent_self
  verified_by            String? @db.Uuid
  verified_at            DateTime @default(now()) @db.Timestamptz(6)
  notes                  String?
  created_at             DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  attendance_session ChildAttendanceSession @relation(fields: [attendance_session_id], references: [id], onDelete: Cascade)

  @@index([verified_at], map: "idx_pickup_verifications_verified_at")
  @@map("pickup_verifications")
}

// ─── plans ────────────────────────────────────────────────────────────────────
// Catalog of available subscription tiers (3/4/5 nights).
// CHECK: nights_per_week BETWEEN 1 AND 7
model Plan {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name               String
  nights_per_week    Int
  weekly_price_cents Int
  active             Boolean @default(true)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  overnight_blocks OvernightBlock[]

  @@unique([nights_per_week], map: "uniq_plans_nights_per_week")
  @@map("plans")
}

// ─── overnight_blocks ─────────────────────────────────────────────────────────
// Per-user weekly booking record. Prices are snapshots at time of purchase.
// CHECK: status IN (active, cancelled, canceled_low_enrollment)
// CHECK: payment_status IN (pending, confirmed, locked)
model OvernightBlock {
  id                       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  week_start               DateTime @db.Date
  parent_id                String  @db.Uuid
  child_id                 String  @db.Uuid
  plan_id                  String? @db.Uuid  // nullable — plan catalog may not be populated
  nights_per_week          Int
  weekly_price_cents       Int
  multi_child_discount_pct Int     @default(0)
  status                   String  @default("active")
  payment_status           String  @default("pending")
  stripe_subscription_id   String?
  stripe_invoice_id        String?
  caregiver_notes          String?  // Parent-provided care instructions (max 500 chars)
  archived_at              DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  parent       Parent        @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  child        Child         @relation(fields: [child_id], references: [id], onDelete: Cascade)
  plan         Plan?         @relation(fields: [plan_id], references: [id])
  reservations Reservation[]
  credits      Credit[]
  payments     Payment[]

  @@index([week_start], map: "idx_blocks_week_start")
  @@index([parent_id, week_start], map: "idx_blocks_parent_week")
  @@index([child_id, week_start], map: "idx_blocks_child_week")
  @@map("overnight_blocks")
}

// ─── reservations ─────────────────────────────────────────────────────────────
// Individual night bookings linked to an overnight_block.
// Partial unique index (child_id, date) WHERE status NOT IN ('canceled_low_enrollment')
// is maintained in SQL — Prisma cannot express partial unique indexes.
// CHECK: status IN (pending_payment, confirmed, locked, canceled, canceled_low_enrollment)
model Reservation {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  child_id           String  @db.Uuid
  date               DateTime @db.Date
  overnight_block_id String  @db.Uuid
  status             String  @default("pending_payment")
  admin_override     Boolean @default(false)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child               Child                    @relation(fields: [child_id], references: [id], onDelete: Cascade)
  overnight_block     OvernightBlock           @relation(fields: [overnight_block_id], references: [id], onDelete: Cascade)
  attendance_sessions  ChildAttendanceSession[]
  reservation_events   ReservationEvent[]
  reservation_nights   ReservationNight[]

  @@index([date], map: "idx_reservations_date")
  @@index([overnight_block_id], map: "idx_reservations_block")
  @@map("reservations")
}

// ─── nightly_capacity ─────────────────────────────────────────────────────────
// Authoritative per-night capacity state.
// CHECK: status IN (open, full, canceled_low_enrollment, canceled_admin)
model NightlyCapacity {
  date              DateTime @id @db.Date
  capacity          Int      @default(6)
  min_enrollment    Int      @default(4)
  confirmed_count   Int      @default(0)
  status            String   @default("open")
  override_capacity Int?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("nightly_capacity")
}

// ─── waitlist ─────────────────────────────────────────────────────────────────
// CHECK: status IN (waiting, offered, accepted, expired, removed)
model WaitlistEntry {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  date       DateTime  @db.Date
  child_id   String    @db.Uuid
  parent_id  String    @db.Uuid
  status     String    @default("waiting")
  offered_at DateTime? @db.Timestamptz(6)
  expires_at DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  child  Child  @relation(fields: [child_id], references: [id], onDelete: Cascade)
  parent Parent @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@index([date, status, created_at], map: "idx_waitlist_fifo")
  @@index([parent_id], map: "idx_waitlist_parent")
  @@map("waitlist")
}

// ─── payments ─────────────────────────────────────────────────────────────────
// Payment records from Stripe webhooks and checkout sessions.
model Payment {
  id                       String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id                String  @db.Uuid
  plan_id                  String? @db.Uuid  // FK to overnight_blocks
  amount_cents             Int
  status                   String  @default("pending") // pending, succeeded, failed, refunded, comped
  description              String?
  stripe_payment_intent_id String?
  stripe_invoice_id        String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  parent         Parent          @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  overnight_block OvernightBlock? @relation(fields: [plan_id], references: [id], onDelete: SetNull)

  @@index([parent_id], map: "idx_payments_parent_id")
  @@index([status], map: "idx_payments_status")
  @@map("payments")
}

// ─── billing_ledger ──────────────────────────────────────────────────────────
// Canonical per-night billing line items for revenue tracking.
model BillingLedger {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id                String    @db.Uuid
  reservation_night_id     String?   @db.Uuid
  child_id                 String?   @db.Uuid
  amount_cents             Int       @default(0)
  status                   String    @default("pending") // pending, paid, failed, refunded, comped
  payment_provider         String?   @default("stripe")
  stripe_payment_intent_id String?
  description              String?
  care_date                DateTime? @db.Date

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  parent           Parent           @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  reservation_night ReservationNight? @relation(fields: [reservation_night_id], references: [id], onDelete: SetNull)
  child            Child?           @relation(fields: [child_id], references: [id], onDelete: SetNull)

  @@index([parent_id], map: "idx_billing_ledger_parent")
  @@index([status], map: "idx_billing_ledger_status")
  @@index([care_date], map: "idx_billing_ledger_care_date")
  @@index([reservation_night_id], map: "idx_billing_ledger_night")
  @@map("billing_ledger")
}

// ─── admin_settings ──────────────────────────────────────────────────────────
// Global admin configuration. Single row expected.
model AdminSettings {
  id                   String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  max_capacity         Int    @default(6)
  min_enrollment       Int    @default(4)
  pricing_tiers        Json   @default("[{\"nights\":3,\"price_cents\":30000},{\"nights\":4,\"price_cents\":36000},{\"nights\":5,\"price_cents\":42500}]") @db.JsonB
  operating_nights     Json   @default("[\"sunday\",\"monday\",\"tuesday\",\"wednesday\",\"thursday\"]") @db.JsonB
  billing_day          String @default("friday")
  billing_time         String @default("12:00")
  waitlist_confirm_hours Int  @default(24)
  overnight_start_time String @default("21:00")
  overnight_end_time   String @default("07:00")

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("admin_settings")
}

// ─── credits ──────────────────────────────────────────────────────────────────
// CHECK: reason IN (canceled_low_enrollment, admin_manual, refund)
model Credit {
  id                       String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id                String    @db.Uuid
  amount_cents             Int
  reason                   String
  related_block_id         String?   @db.Uuid
  related_date             DateTime? @db.Date
  source_weekly_price_cents Int?
  source_plan_nights       Int?
  applied                  Boolean   @default(false)
  applied_at               DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  parent        Parent          @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  related_block OvernightBlock? @relation(fields: [related_block_id], references: [id])

  @@index([parent_id, applied], map: "idx_credits_parent_applied")
  @@index([related_date], map: "idx_credits_related_date")
  @@map("credits")
}

// ─── audit_log ────────────────────────────────────────────────────────────────
model AuditLog {
  id          String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actor_id    String? @db.Uuid
  action      String
  entity_type String
  entity_id   String? @db.Uuid
  metadata    Json    @default("{}") @db.JsonB

  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  actor Parent? @relation(fields: [actor_id], references: [id])

  @@index([entity_type, entity_id], map: "idx_audit_log_entity")
  @@index([created_at], map: "idx_audit_log_created")
  @@map("audit_log")
}

// ─── pickup_events ───────────────────────────────────────────────────────────
// Logs every child pickup for legal protection and parent notifications.
// Created automatically when staff verifies a pickup via PIN or photo ID.
model PickupEvent {
  id                  String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  child_id            String   @db.Uuid
  pickup_person_id    String?  @db.Uuid
  verified_by_staff_id String? @db.Uuid
  verification_method String   // 'pin' | 'photo_id' | 'parent_self'
  notes               String?
  created_at          DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  child         Child                  @relation(fields: [child_id], references: [id], onDelete: Cascade)
  pickup_person ChildAuthorizedPickup? @relation(fields: [pickup_person_id], references: [id], onDelete: SetNull)
  verified_by   Parent?                @relation("pickup_verifier", fields: [verified_by_staff_id], references: [id])

  @@index([child_id, created_at], map: "idx_pickup_events_child")
  @@map("pickup_events")
}

// ─── parent_settings ────────────────────────────────────────────────────────
// Per-parent notification, safety, and preference settings.
model ParentSettings {
  id                       String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  parent_id                String   @unique @db.Uuid
  email_notifications      Boolean  @default(true)
  sms_notifications        Boolean  @default(false)
  reservation_reminders    Boolean  @default(true)
  billing_reminders        Boolean  @default(true)
  emergency_alerts         Boolean  @default(true)
  require_pickup_pin       Boolean  @default(true)
  notify_on_check_in_out   Boolean  @default(true)
  notify_on_pickup_changes Boolean  @default(true)
  emergency_contact_reminder Boolean @default(true)
  preferred_contact_method String?
  preferred_reminder_timing String?
  staff_notes              String?
  language_preference      String?

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  parent Parent @relation(fields: [parent_id], references: [id], onDelete: Cascade)

  @@map("parent_settings")
}

// ─── config ───────────────────────────────────────────────────────────────────
// Key-value application configuration.
model Config {
  key   String @id
  value String

  @@map("config")
}

// ─── stripe_prices ───────────────────────────────────────────────────────────
// Cache of Stripe price IDs per tier/mode.
model StripePrice {
  tier       String
  price_id   String
  mode       String   // 'test' | 'live'
  updated_at DateTime @default(now()) @db.Timestamptz(6)

  @@unique([tier, mode])
  @@map("stripe_prices")
}

// ─── subscriptions ───────────────────────────────────────────────────────────
// Stripe subscription records for the Express billing system (legacy).
// CHECK: status IN (active, past_due, canceled, incomplete)
// CHECK: plan_tier IN (plan_3n, plan_4n, plan_5n)
model Subscription {
  id                     String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  parent_id              String    @db.Uuid
  stripe_subscription_id String    @unique
  plan_tier              String
  status                 String    @default("active")
  stripe_status          String?
  next_billing_date      DateTime? @db.Timestamptz(6)
  current_period_end     DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  parent              Parent             @relation(fields: [parent_id], references: [id], onDelete: Cascade)
  pending_plan_change PendingPlanChange?
  billing_events      BillingEvent[]

  @@map("subscriptions")
}

// ─── pending_plan_changes ────────────────────────────────────────────────────
// CHECK: new_plan_tier IN (plan_3n, plan_4n, plan_5n)
model PendingPlanChange {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  subscription_id String   @unique @db.Uuid
  new_plan_tier   String
  effective_date  DateTime @db.Date

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  subscription Subscription @relation(fields: [subscription_id], references: [id], onDelete: Cascade)

  @@map("pending_plan_changes")
}

// ─── billing_events ──────────────────────────────────────────────────────────
// Stripe webhook idempotency. INSERT ON CONFLICT IGNORE pattern.
model BillingEvent {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  stripe_event_id   String    @unique
  event_type        String
  subscription_id   String?   @db.Uuid
  payload           Json      @db.JsonB
  livemode          Boolean   @default(false)
  stripe_created_at DateTime? @db.Timestamptz(6)
  status            String    @default("received") // received, processed, failed, skipped
  error             String?
  processed_at      DateTime? @db.Timestamptz(6)

  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  subscription Subscription? @relation(fields: [subscription_id], references: [id])

  @@map("billing_events")
}

// ─── reservation_nights ──────────────────────────────────────────────────────
// Per-night booking records linked to a reservation, child, and program capacity.
// Each row represents one booked night. Links to program_capacity for availability tracking.
// CHECK: status IN (pending, confirmed, cancelled, completed, waitlisted, no_show)
model ReservationNight {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservation_id       String   @db.Uuid
  child_id             String   @db.Uuid
  program_capacity_id  String?  @db.Uuid
  care_date            DateTime @db.Date
  status               String   @default("pending") // CHECK: pending | confirmed | cancelled | completed | waitlisted | no_show
  capacity_snapshot    Int

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  reservation      Reservation      @relation(fields: [reservation_id], references: [id], onDelete: Cascade)
  child            Child            @relation(fields: [child_id], references: [id], onDelete: Cascade)
  program_capacity ProgramCapacity? @relation(fields: [program_capacity_id], references: [id], onDelete: SetNull)
  attendance_record AttendanceRecord?
  billing_ledger    BillingLedger[]

  @@unique([reservation_id, care_date], map: "reservation_nights_reservation_date_unique")
  @@unique([child_id, care_date], map: "reservation_nights_child_date_unique")
  @@index([reservation_id], map: "idx_reservation_nights_reservation")
  @@index([care_date], map: "idx_reservation_nights_date")
  @@map("reservation_nights")
}

// ─── idempotency_keys ────────────────────────────────────────────────────────
// Stores idempotency keys for critical POST/PATCH APIs.
// Keys expire after 24 hours. Clients send Idempotency-Key header;
// duplicate requests return the cached response.
// Managed by service role only — no user-facing RLS policies.
model IdempotencyKey {
  key             String   @id
  user_id         String?  @db.Uuid
  request_path    String
  response_status Int
  response_body   Json     @default("{}") @db.JsonB
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  expires_at      DateTime @default(dbgenerated("(now() + interval '24 hours')")) @db.Timestamptz(6)

  @@index([expires_at], map: "idx_idempotency_keys_expires")
  @@index([user_id], map: "idx_idempotency_keys_user")
  @@map("idempotency_keys")
}

// ─── attendance_records ─────────────────────────────────────────────────────
// Canonical attendance state for a single child on a single reserved night.
// One-to-one with reservation_nights. Tracks check-in, check-out, pickup
// verification, no-show, and late arrival. All mutations emit attendance_events.
model AttendanceRecord {
  id                         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reservation_night_id       String    @unique @db.Uuid
  center_id                  String?   @db.Uuid
  child_id                   String    @db.Uuid
  parent_id                  String    @db.Uuid
  care_date                  DateTime  @db.Date

  // CHECK: expected | checked_in | checked_out | no_show | cancelled
  attendance_status          String    @default("expected")

  // Check-in fields
  expected_arrival_at        DateTime? @db.Timestamptz(6)
  checked_in_at              DateTime? @db.Timestamptz(6)
  checked_in_by_user_id      String?   @db.Uuid
  check_in_method            String?   // staff_manual | parent_acknowledged | system | override
  arrival_notes              String?

  // Check-out / pickup fields
  expected_departure_at      DateTime? @db.Timestamptz(6)
  checked_out_at             DateTime? @db.Timestamptz(6)
  checked_out_by_user_id     String?   @db.Uuid
  check_out_method           String?   // staff_manual | parent_acknowledged | system | override
  checked_out_to_pickup_id   String?   @db.Uuid
  pickup_verification_status String?   // not_applicable | pending | verified | failed | manual_override
  departure_notes            String?

  // No-show fields
  no_show_marked_at          DateTime? @db.Timestamptz(6)
  no_show_marked_by_user_id  String?   @db.Uuid

  // Exception tracking
  cancellation_after_cutoff  Boolean   @default(false)
  late_arrival_minutes       Int       @default(0)

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  reservation_night ReservationNight @relation(fields: [reservation_night_id], references: [id], onDelete: Cascade)
  events            AttendanceEvent[]

  @@index([center_id, care_date], map: "idx_attendance_records_center_date")
  @@index([child_id, care_date], map: "idx_attendance_records_child_date")
  @@index([attendance_status, care_date], map: "idx_attendance_records_status_date")
  @@index([parent_id], map: "idx_attendance_records_parent")
  @@map("attendance_records")
}

// ─── attendance_events ──────────────────────────────────────────────────────
// Immutable event log for attendance actions. Never update or delete rows.
// Provides full audit trail for check-in, check-out, no-show, corrections.
model AttendanceEvent {
  id                   String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  attendance_record_id String   @db.Uuid
  reservation_night_id String   @db.Uuid
  center_id            String?  @db.Uuid
  child_id             String   @db.Uuid
  actor_user_id        String?  @db.Uuid

  // Event types: attendance_record_created | child_checked_in | late_arrival_recorded
  //   | child_checked_out | pickup_verified | pickup_verification_failed
  //   | no_show_marked | attendance_status_corrected | attendance_cancelled
  event_type           String
  event_at             DateTime @default(now()) @db.Timestamptz(6)
  metadata             Json     @default("{}") @db.JsonB

  // Relations
  attendance_record AttendanceRecord @relation(fields: [attendance_record_id], references: [id], onDelete: Cascade)

  @@index([attendance_record_id, event_at], map: "idx_attendance_events_record")
  @@index([reservation_night_id, event_at], map: "idx_attendance_events_night")
  @@index([center_id, event_at], map: "idx_attendance_events_center")
  @@index([event_type, event_at], map: "idx_attendance_events_type")
  @@map("attendance_events")
}

// ─── health_check_runs ───────────────────────────────────────────────────────
// Tracks executions of reconciliation sweeps.
// CHECK: run_type IN (manual, scheduled, startup, repair_followup)
// CHECK: status IN (running, completed, failed)
model HealthCheckRun {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  run_type              String    // manual | scheduled | startup | repair_followup
  started_at            DateTime  @default(now()) @db.Timestamptz(6)
  completed_at          DateTime? @db.Timestamptz(6)
  status                String    @default("running") // running | completed | failed
  triggered_by_user_id  String?   @db.Uuid
  summary               Json      @default("{}") @db.JsonB

  created_at DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  issues HealthIssue[]

  @@index([status, started_at], map: "idx_health_runs_status")
  @@index([triggered_by_user_id], map: "idx_health_runs_user")
  @@map("health_check_runs")
}

// ─── health_issues ───────────────────────────────────────────────────────────
// Stores current and historical detected integrity issues.
// CHECK: severity IN (critical, warning, info)
// CHECK: status IN (open, reviewed, resolved, ignored)
model HealthIssue {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  health_check_run_id   String    @db.Uuid
  issue_type            String
  severity              String    // critical | warning | info
  status                String    @default("open") // open | reviewed | resolved | ignored
  center_id             String?   @db.Uuid
  program_id            String?   @db.Uuid
  care_date             DateTime? @db.Date
  reservation_night_id  String?   @db.Uuid
  attendance_record_id  String?   @db.Uuid
  child_id              String?   @db.Uuid
  metadata              Json      @default("{}") @db.JsonB
  detected_at           DateTime  @default(now()) @db.Timestamptz(6)
  resolved_at           DateTime? @db.Timestamptz(6)
  resolved_by_user_id   String?   @db.Uuid
  resolution_notes      String?

  // Relations
  health_check_run HealthCheckRun @relation(fields: [health_check_run_id], references: [id], onDelete: Cascade)

  @@index([health_check_run_id], map: "idx_health_issues_run")
  @@index([severity, status], map: "idx_health_issues_severity_status")
  @@index([issue_type, status], map: "idx_health_issues_type")
  @@index([care_date], map: "idx_health_issues_date")
  @@map("health_issues")
}
